# Bitbucket Authentication (Required)
# Use your Atlassian email for API Tokens, or Bitbucket username for App Passwords
BITBUCKET_USERNAME=

# Use your Bitbucket App Password or API Token (ATBB)
BITBUCKET_API_TOKEN=

# Default Workspace (Optional)
BITBUCKET_WORKSPACE=

# API URL (Optional, defaults to https://api.bitbucket.org/2.0)
BITBUCKET_URL=

# Operation Mode (Optional, default: safe)
# readonly: Only GET operations
# safe: GET + POST/PUT, no deletes (default)
# full: All operations including dangerous deletes
# BITBUCKET_MODE=safe

# Fine-grained Tool Control (Optional)
# Whitelist: Only enable specific tools (comma-separated)
# BITBUCKET_ENABLED_TOOLS=getPullRequest,listPullRequests,getPullRequestDiff

# Blacklist: Disable specific tools (comma-separated)
# BITBUCKET_DISABLED_TOOLS=deleteBranch,deleteRepository,deleteTag

# Logging (Optional)
# BITBUCKET_LOG_DISABLE=false
# BITBUCKET_LOG_FILE=/path/to/custom.log
# BITBUCKET_LOG_DIR=/path/to/logs
# BITBUCKET_LOG_PER_CWD=false
